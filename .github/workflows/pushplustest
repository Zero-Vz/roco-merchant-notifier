import os
import requests

PUSHPLUS_TOKEN = os.getenv("PUSHPLUS_TOKEN", "")
print("Token:", PUSHPLUS_TOKEN[:5], "..." if PUSHPLUS_TOKEN else "未设置")
if PUSHPLUS_TOKEN:
    resp = requests.post('http://www.pushplus.plus/send', json={
        "token": PUSHPLUS_TOKEN,
        "title": "测试推送",
        "content": "这是一条GitHub Actions测试推送",
        "template": "markdown"
    })
    print("PushPlus 返回：", resp.text)
else:
    print("未检测到 PUSHPLUS_TOKEN，推送跳过")
